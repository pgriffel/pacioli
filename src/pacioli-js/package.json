{
  "name": "pacioli-ts",
  "version": "0.5.0",
  "description": "Pacioli typescript runtime system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "tsc --project tsconfig.test.json && jasmine",
    "build": "tsc",
    "bundle": "tsc && webpack",
    "bundle:win": "tsc && webpack && copy dist\\pacioli-0.5.0.bundle.js ..\\..\\samples && copy dist\\pacioli-0.5.0.bundle.js ..\\..\\test",
    "bundle:linux": "tsc && webpack && copy dist/pacioli-0.5.0.bundle.js ../../samples && copy dist/pacioli-0.5.0.bundle.js ..//../test"
  },
  "author": "Paul Griffioen",
  "license": "MIT",
  "dependencies": {
    "bignumber.js": "^9.1.2",
    "d3": "^7.4.4",
    "d3-cloud": "^1.2.5",
    "numeric": "^1.2.6",
    "three": "^0.171.0",
    "uom-ts": "file:uom-ts-0.0.1.tgz"
  },
  "devDependencies": {
    "@types/bignumber.js": "^5.0.0",
    "@types/d3": "^7.1.0",
    "@types/d3-cloud": "^1.2.5",
    "@types/jasmine": "^4.3.1",
    "@types/node": "^18.15.10",
    "@types/numeric": "^1.2.2",
    "@types/three": "^0.149.0",
    "@types/webpack": "^5.28.0",
    "fast-check": "^2.20.0",
    "jasmine": "^4.6.0",
    "jasmine-spec-reporter": "^7.0.0",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.4.0",
    "typescript": "^4.5.4",
    "webpack": "^5.76.2",
    "webpack-cli": "^5.0.1"
  }
}
