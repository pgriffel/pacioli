{
  "name": "uom-ts",
  "version": "0.0.2",
  "description": "units of measurement for javascript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest",
    "test:longruns": "vitest --config vitest.config.longruns.js",
    "build": "node esbuild.js && tsc --emitDeclarationOnly",
    "build:tsc": "tsc",
    "package": "npm run build && npm pack",
    "package:tsc": "npm run build:tsc && npm pack"
  },
  "author": "Paul Griffioen",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "~0.25.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "fast-check": "^4.2.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "bignumber.js": "^9.3.1"
  }
}
