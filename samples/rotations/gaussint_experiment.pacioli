#declare gcd2 :: for_unit a: (M_Complex(a), M_Complex(a)) -> M_Complex(a);

#define gcd2(a, b) = 



#"det2d(m_make_complex(3, 4))";
#det2d(m_make_complex(3, 4));

#"less2d(m_make_complex(3, 4), m_make_complex(5,0))";
#less2d(m_make_complex(3, 4), m_make_complex(5,0));

# positive integer a, b!
define gcd2(a, b) = 
begin
    while b != 0 do
        t := b;
        b := mod(a , b);
        a := t;
    end
    return a;
end;

# we define the mod2 function although there is a predefined mod function, as a stepping stone 
# to also study mod2 for the gaussian integers.
# Although mod2(a,b) is mathematically an equivalence relation defining a congruence of numbers
# we make it into a function by selecting one unique "normalized representant", namely the value
# 0 <= mod2(a,b) < b, with both a and b integers, a >= 0 and b > 0.
# 
define mod2(a, b) = 
begin
    while a >= b do
        a := a-b;
    end
    return a;
end;


