declare galilean_transform:: for_unit a: (a * Geom3!, a * Geom3! / second, second) ->
    a * Geom3!;

define galilean_transform(position, velocity, time) = 
    position + velocity '*.' time;

"galilean transform";
galilean_transform(vector3d(10,11,12) '*.' |metre|, velocity_si, 2 * |second|);

