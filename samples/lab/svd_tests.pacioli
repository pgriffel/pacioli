# declare check_svd_hart :: for_index A, B, C: (A! per A!, B! per A!, C! per A!) -> Boole;
# declare check_svd_hart ::
#     for_index C, D, E, F:
#     for_unit a, C!b: (a*C!b per D!, E! per D!, 1/a*F! per C!b) -> Boole;

# declare check_svd_hart ::
#     for_index C, D, E, F:
#     for_unit a, C!b: (a*C!b per D!, E! per D!, 1/a*F! per C!b) -> Boole;

# declare check_svd_hart ::
#     for_index E, F, G, H:
#     for_unit a, b, E!c, F!d: (a*E!c per F!d, b*G! per F!d, b/a*H! per E!c) -> Boole;

define check_svd_hart(matrix, Qx, Qy) =
    let
        Px = Qx^T '*' Qx,
        Py = Qy^T '*' Qy
    in
        all[is_orthogonal_pair_metric(Py, v1, v2) 
                and
            is_orthogonal_pair_metric(Px, w1, w2)
            |
            decomp := hart_svd(Qx, Qy)(matrix),
                (s1,v1,w1) <- decomp,
                (s2,v2,w2) <- decomp] 
    end;

declare check_svd_hart2 ::
    for_index E, F, G, H:
    for_unit a, b, E!c, F!d:
        (a*E!c per F!d, b*G! per F!d, b/a*H! per E!c) -> 
            List(Tuple(
                    Tuple(b^2/a^2/E!c per E!c, a/b*E!c, a/b*E!c), 
                    Tuple(b^2/F!d per F!d, b/F!d, b/F!d)));

define check_svd_hart2(matrix, Qx, Qy) =
    let
        Px = Qx^T '*' Qx,
        Py = Qy^T '*' Qy
    in
        [tuple(tuple(Py, v1, v2),
                #and
            tuple(Px, w1, w2))
            |
            decomp := hart_svd(Qx, Qy)(matrix),
                (s1,v1,w1) <- decomp,
                (s2,v2,w2) <- decomp] 
    end;


declare is_orthogonal_pair_metric ::
    for_index C:
    for_unit a, C!b: (a^2*C!b per 1/C!b, 1/a/C!b, 1/a/C!b) -> Boole;

define is_orthogonal_pair_metric(M, v, w) =
    bilinear_form(M)(v,w) ~= if v = w then 1 else 0 end;



