import testing;
import testdata;
import si;
import metrics;
include metrics_experiments;

declare is_js :: Boole;
define is_js = format("%d", |metre|) = "1";

declare base_suites :: List(TestSuite);

define base_suites = [
    svd_suite,
    dimless_svd_suite,
    hart_svd_suite
];

run_test_suites(base_suites); 
# ------------------------------------------------------------------------------
# Function svd
# ------------------------------------------------------------------------------

# The js version produces NaN numbers for some test cases. For now this is checked
# and an error is thrown. The Java version doesn't throw errors for these cases.
# Therefore the js variant requires a catch_with_skip and the Java variant a
# catch_with_fail. The tmp_catch function is a convenience function to make that
# distinction, until this is addressed.

declare tmp_catch :: (() -> Boole) -> Maybe(Boole);

define tmp_catch(f) = 
    if is_js then catch_with_skip(f) else catch_with_fail(f) end;

define svd_suite = test_suite("Function svd", [

    test("should give factor 0 for svd(0)", () ->
        let (a, _, _) = nth(0, svd(0)) in a = 0 end),
      
    random_test("should give the correct factor for scalars", () ->
        let
            num = random() * |metre|,
            svd_result = svd(num)
        in
            if list_size(svd_result) = 1 then
                let (a, _, _) = nth(0, svd_result) in
                    just(a = num)
                end
            else
                just(false)
            end
        end),

    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- svd(A)], precision)
            end)),

    # test is factorization leads to orthogonal vectors
    random_test("should be an orthogonal factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                # check_svd_1(A)
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- svd(A)], precision)
            end)),
    
    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- svd(A)], precision)
            end)),

    random_test("should be a proper factorization when nr column > nr rows 3x4 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()^T
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- svd(A)], precision)
            end))
]);

define dimless_svd_suite = test_suite("Function dimless_svd", [

    test("should give factor 0 for dimless_svd(0)", () ->
        let (a, _, _) = nth(0, svd(0)) in a = 0 end),
      
    random_test("should give the correct factor for scalars", () ->
        let
            num = random(),
            svd_result = dimless_svd(num)
        in
            if list_size(svd_result) = 1 then
                let (a, _, _) = nth(0, svd_result) in
                    just(a = num)
                end
            else
                just(false)
            end
        end),

    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- dimless_svd(A)], precision)
            end)),

    # test is factorization leads to orthogonal vectors
    random_test("should be an orthogonal factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                # check_svd_1(A)
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- dimless_svd(A)], precision)
            end)),
    
    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- dimless_svd(A)], precision)
            end)),

    random_test("should be a proper factorization when nr column > nr rows 3x4 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()^T
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- dimless_svd(A)], precision)
            end)),

    random_test("should lead to orthogonal vectors v and w in a 3x4 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()^T 
            in
                check_dimless_svd_test(A)
            end))    
]);

define hart_svd_suite = test_suite("Function hart_svd", [
    test("should give factor 0 for hart_svd(1,1)(0)", () ->
        let (a, _, _) = nth(0, hart_svd(1,1)(0)) in a = 0 end),
      
    random_test("should give the correct factor for scalars", () ->
        let
            num = random(),
            svd_result = hart_svd(1, 1)(num)
        in
            if list_size(svd_result) = 1 then
                let (a, _, _) = nth(0, svd_result) in
                    just(a = num)
                end
            else
                just(false)
            end
        end),

    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix() * |Four!unit per Three!unit|
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- hart_svd(Q_33, Q_44)(A)], precision)
            end)),

    # test is factorization leads to orthogonal vectors
    random_test("should be an orthogonal factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix() * |Four!unit per Three!unit|
            in
                # check_svd_1(A)
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- hart_svd(Q_33, Q_44)(A)], precision)
            end)),
    
    random_test("should be a proper factorization 4x3 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix() * |Four!unit per Three!unit|
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- hart_svd(Q_33, Q_44)(A)], precision)
            end)),

    random_test("should be a proper factorization when nr column > nr rows 3x4 matrix", () ->
        tmp_catch(()->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_3_matrix()^T * |Three!unit per Four!unit|
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- hart_svd(Q_44, Q_33)(A)], precision)
            end))  

    # random_test("should lead to orthogonal vectors v and w in a 3x4 matrix", () ->
        # tmp_catch(()->
        #     let
        #         # Doesn't make the default 14 decimals
        #         precision = 10*|decimals|,
        #         A = random_4_by_3_matrix()^T * |Three!unit per Four!unit|
        #     in
        #         check_svd_hart_test(A, Q_44, Q_33)
        #     end))    
]);


define check_dimless_svd(matrix) =
    all[is_orthogonal_pair_dimless(v1, v2) and is_orthogonal_pair_dimless(w1, w2)| 
        decomp := svd(matrix),
        (s1,v1,w1) <- decomp,
        (s2,v2,w2) <- decomp];

define check_dimless_svd_test(matrix) =
    all[
        is_orthogonal_pair_dimless(v1, v2)
            and
        is_orthogonal_pair_dimless(w1, w2)
            | 
        decomp := svd(matrix),
        (s1,v1,w1) <- decomp,
        (s2,v2,w2) <- decomp];

define is_orthogonal_pair_dimless(v, w) =
    inner(v, w) ~= if v = w then 1 else 0 end;

