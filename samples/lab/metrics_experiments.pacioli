[w^R | (_, _, w) <- svd(Q_44)];

# declare test_svd :: for_index E, F: for_unit a, b, E!c, g, F!d:
#   (a*E!c per F!d, g*E!c per E!c, b*E!c per F!d, a/b/g/F!d per 1/F!d) -> Boole;

define test_svd(A, U, S, V) = 
  (U '*' U^T = left_identity(A)) and
  (U '*' U^-1 = left_identity(A)) and
  (V '*' V^T = right_identity(A)) and
  (V '*' V^-1 = right_identity(A)) and
  (A = U '*' S '*' V^T);



