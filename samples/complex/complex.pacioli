# ----------------------------------------------------------------------------
# Complex
#
# ----------------------------------------------------------------------------

import geometry;
import quaternion;
import complex;

# ----------------------------------------------------------------------------
# The Complex type
# We assume one and the same dimension of both 1 and i.
# ----------------------------------------------------------------------------

doc Complex
    "The type of Complex numbers; as an alias for ComplexMatrix(a, 1, 1).";

deftype for_unit a: Complex(a) = ComplexMatrix(a, 1, 1);



# ----------------------------------------------------------------------------
# Other representations
# ----------------------------------------------------------------------------

declare matrix_representation :: 
    for_unit a: (Complex(a)) -> a * Geom2! per Geom2!;

define matrix_representation(x) = 
    let
        (re, im) = get_scalar_tuple(x)
    in
        matrix2d(re, -im, im, re)
    end;



declare quaternion_representation :: 
    for_unit a: (Complex(a)) -> Quaternion(a);

define quaternion_representation(x) = 
    let
        (re, im) = get_scalar_tuple(x)
    in
        make_quaternion(re, im, 0 * re, 0 * re)
    end;
