import si;
import testing;

include kirchhof;


run_test_suites(kirchhof_suites);


declare kirchhof_suites :: List(TestSuite);

define kirchhof_suites = [
    kirchhof_suite
];


define kirchhof_suite = test_suite("Kirchhof", [
    test("should solve correctly", () ->
        run_case()
    )
]);
