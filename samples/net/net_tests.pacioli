import testing;
import petri_net;

include net;
include net_behavior;

run_test_suites(net_suites);

declare net_suites :: List(TestSuite);

define net_suites = [
    net_suite
];

# ------------------------------------------------------------------------------
# Test data
# ------------------------------------------------------------------------------

define test_marking(p0, p1, p2) =
    p0 '.*' delta(Place@p0) +
    p1 '.*' delta(Place@p1) +
    p2 '.*' delta(Place@p2);

define inc_p1_and_p2_trace = 
    trace([
        tuple(Transition@t1, 1),
        tuple(Transition@t2, 1),
        tuple(Transition@t1, 1),
        tuple(Transition@t2, 1),
        tuple(Transition@t1, 1)
    ]);

# ------------------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------------------

define net_suite = test_suite("Petri net", [

    test("should start with the correct initial marking", () ->
        petri_net_marking(test_net) = test_marking(0*|token|, 1*|token|, 1*|token|)
    ),

    test("should start with only transition t0 enabled", () ->
        enabled_transitions(test_net) = [Transition@t0]
    ),

    test("should enable t1 and t2 after firing t0", () ->
        let 
            (net, _, _, _, _) = run_petri_net_trace(test_net, trace([tuple(Transition@t0, 1)]))
        in
            enabled_transitions(net) = [Transition@t0, Transition@t1, Transition@t2]
        end
    ),

    test("should not enable 2*t2 after firing t0 once", () ->
        let
            (net, _, _, _, _) = run_petri_net_trace(test_net, trace([tuple(Transition@t0, 1)]))
        in
            not(petri_net_enabled(net, 2 '.*' delta(Transition@t1))) and
            not(petri_net_enabled(net, 2 '.*' delta(Transition@t2)))
        end
    ),

    test("should increase p1 and p2 by one when running inc_p1_and_p2_trace", () ->
        let
            init = trace([tuple(Transition@t0, 1)]),

            (net, _, _, _, _) =
                run_petri_net_trace(test_net, init ++ inc_p1_and_p2_trace)
        in
            petri_net_marking(net) = test_marking(1*|token|, 2*|token|, 2*|token|)
        end
    ),

    test("should enable i*ti + j*t2 after firing t0 > i+j times", () ->
        let 
            n = 10,

            init = trace([tuple(Transition@t0, n)]),
            inc_n_times = [x | _ <- naturals(n), x <- inc_p1_and_p2_trace],

            (net, _, _, _, _) = run_petri_net_trace(test_net, init ++ inc_n_times)
        in
            all[ petri_net_enabled(net, firing)  <=>  i + j <= n |
                    i <- naturals(n),
                    j <- naturals(n),
                    firing := i '.*' delta(Transition@t1) + j '.*' delta(Transition@t2)]
        end
    )
]);
