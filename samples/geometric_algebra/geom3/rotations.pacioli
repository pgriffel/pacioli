define make_rotor(n, m) = 
    # Hier gebleven; normaliseren van de vectoren m en n - als multivectoren 
    # conform Leo p172 vergt deling door de norm van R, maar:
    # - we hebben geen sqrt van een multivector EN 
    # - we willen een genormaliseerde vector MET unit zoals 1m.
    # De berekening maakt nu een dimless rotor.
    # Nog nagaan - zie 6.22 en 6.23 - de k-grade selection operator.
    #
    let
        rotor = geometric_product(n, m),
        rotor_norm_square = geometric_product(rotor, multivector_reverse(rotor))
    in
        geometric_product(rotor, geometric_product(rotor, multivector_inverse(rotor_norm_square)))
    end;

# Leo's formule op p170
define make_rotor_leo(n, m) = 
    geometric_product(n, multivector_inverse(m));

define make_rotor_doran(n, m) =
    geometric_product(normalise(n), normalise(m));

define normalise(n) =
    let 
        in_nn = left_contraction(n, n)
    in 
        geometric_product(n, geometric_product(n, multivector_inverse(in_nn)))
    end;



define rotate (a, rotor) =
    geometric_product(geometric_product(rotor, a), multivector_reverse(rotor));
