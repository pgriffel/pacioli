# ------------------------------------------------------------------------------
# Test utilities
# ------------------------------------------------------------------------------

export
    Test,
    TestSuite,
    test,
    random_test,
    test_focus,
    random_test_focus,
    test_description,
    is_test_focused,
    run_test,
    catch_with_fail, 
    catch_with_skip,
    test_suite,
    test_suite_focus,
    suite_description,
    suite_tests,
    is_suite_focused,
    run_test_suites;

declare test, test_focus :: (String, () -> Boole) -> Test;
declare random_test, random_test_focus :: (String, () -> Maybe(Boole)) -> Test;
declare is_test_focused :: (Test) -> Boole;
declare run_test :: (Test) -> Boole;

declare test_suite, test_suite_focus :: (String, List(Test)) -> TestSuite;
declare is_suite_focused :: (TestSuite) -> Boole;
declare run_test_suites :: (List(TestSuite)) -> Void;

# ------------------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------------------

doc Test
    "A test is a tuple <code>(description, check, focused)</code>. 
    
    The desciption explains the test in one line. The check is the actual
    test. The focused flag indicates whether this test is marked as 
    'focused'.";

defrecord Test() as test where
    description: String,
    body: () -> Boole,
    focused: Boole;

# ------------------------------------------------------------------------------

doc test
    "Creates a test. 
    
    The first argument is a description of the test case. The second argument is
    a condition that that test must satisfy.";

define test(description, body) =
    make_test(description , body, false);

# ------------------------------------------------------------------------------

doc test_focus
    "Creates a test, just like function <code>test</code>, but marks it as 'focused'.
    
    When at least one test is marked as 'focused' then function <code>run_test_suites</code>
    will only run the marked tests and skip all others.";

define test_focus(description, body) =
    make_test(description , body, true);

# ------------------------------------------------------------------------------

doc random_test
    "Creates a random test. 
    
    The first argument is a description of the test case. The second argument is
    a Maybe with a condition that that test must satisfy.
    
    The test evaluates the condition repeatedly until hunderd successes have
    been achieved, or until a faillure occurs. The test also fails after thousand
    attempts.
    
    When the condition is the nothing Maybe then it doesn't count as test. This can
    be used as a pre-condition for the test.";

define random_test(description, body) =
    make_test(description , () -> run_random_test_body(description, body), false);

# ------------------------------------------------------------------------------

doc random_test_focus
    "Creates a random test, just like function <code>random_test</code>, but marks
    it as 'focused'.
    
    When at least one test is marked as 'focused' then function <code>run_test_suites</code>
    will only run the marked tests and skip all others.";

define random_test_focus(description, body) =
    make_test(description , () -> run_random_test_body(description, body), true);

# ------------------------------------------------------------------------------

doc is_test_focused
    "Is the test marked as 'focused'.";

define is_test_focused(test) = 
    test_focused(test);

# ------------------------------------------------------------------------------

doc run_test
    "Executes the test.";

define run_test(test) =
    test_body(test)();

# ------------------------------------------------------------------------------
# Tests suite
# ------------------------------------------------------------------------------

doc TestSuite
    "A test suite is a collection of tests.";

defrecord TestSuite() as suite where
    description: String,
    tests: List(Test),
    focused: Boole;

# ------------------------------------------------------------------------------

doc test_suite
    "Creates a test suite.";

define test_suite(description, tests) = 
    make_suite(description, tests, false);

# ------------------------------------------------------------------------------

doc test_suite_focus
    "Creates a test suite, just like function <code>test_suite</code>, but
    marks it as 'focused'";

define test_suite_focus(description, tests) = 
    make_suite(description, tests, true);

# ------------------------------------------------------------------------------

doc is_suite_focused
    "Is the test suite marked as 'focused'";

define is_suite_focused(suite) = 
    suite_focused(suite);

# ------------------------------------------------------------------------------

doc run_test_suites
    "Runs all tests from a list of test suites. Prints output to the terminal.
    Returns the result as triple (nr_tests, nr_failures, nr_skipped).

    When at least one of the tests is marked as 'focused' then it will only run the
    marked tests and skip all others.";

define run_test_suites(suites) =
    begin
        print("\nRuning test suites\n");

        # Determine which suites to run
        to_test :=
            let
                suites_with_focus = [s | s <- suites, is_suite_focused(s)]
            in
                if suites_with_focus = [] then
                    suites
                else
                    suites_with_focus
                end
            end;

        nr_skipped_suites := list_size(suites) - list_size(to_test);

        # Run the tests. Collect the results as a list of (description, result) pairs
        results := [tuple(suite_description(s), run_test_suite(s)) | s <- to_test];

        # Print a status message
        printf("\nTests finished, %d suites tested%s\n",
            list_size(to_test),
            skipped_message(nr_skipped_suites));

        # Print a summary of the results per suite. Also calculate totals.
        total_nr_tests := 0;
        total_nr_successes := 0;

        for (description, result) <- results do

            # Get the result for this suite
            # (description, result) := head(toprint);
            (nr_tests, nr_errors, nr_skipped) := result;
            nr_successes := nr_tests - nr_errors;

            # Print the result
            printf(" %s%s -> %d/%d success%s", 
                if nr_successes = nr_tests then " " else "*" end,
                description,
                nr_successes,
                nr_tests,
                skipped_message(nr_skipped));

            # Update the totals
            total_nr_tests := total_nr_tests + nr_tests;
            total_nr_successes := total_nr_successes + nr_successes;
        end

        # Determine total number of skipped
        total_nr_skipped := count[ true | s <- suites, t <- suite_tests(s)] - total_nr_tests;

        # Print the totals
        printf("\nTotal tests -> %d/%d success%s",
            total_nr_successes,
            total_nr_tests,
            skipped_message(total_nr_skipped));
    end;

# ------------------------------------------------------------------------------
# Helpers
# ------------------------------------------------------------------------------

declare run_test_suite :: (TestSuite) -> Tuple(1, 1, 1);
declare skipped_message :: (1) -> String;

doc run_test_suite
    "Runs all tests for a test suite. Prints output to the terminal. Returns the
    result as triple (nr_tests, nr_failures, nr_skipped).

    When at least one of the tests is marked as 'focused' then it will focus run
    the marked tests and skip all others.";

define run_test_suite(suite) =
    let
        all_tests = suite_tests(suite),

        tests =
            let
                tests_with_focus = [t | t <- all_tests, is_test_focused(t)]
            in
                if tests_with_focus = [] then
                    all_tests
                else
                    tests_with_focus
                end
            end,
        
        nr_tests = list_size(tests),
        nr_skipped = list_size(all_tests) - nr_tests
                        
    in
        begin
            print(suite_description(suite));

            nr_failures := 0;

            for test <- tests do
                okay := run_test(test);
                
                if not(okay) then
                    nr_failures := nr_failures + 1;
                end

                printf("  %s -> %s", 
                    test_description(test),
                    if okay then "ok" else "FAIL!" end);
            end

            if nr_failures = 0 then
                printf("All %d tests succeeded%s\n", nr_tests, skipped_message(nr_skipped));
            else
                printf("\nTEST FAILURES!!!!!\n\n  %d of %d tests failed%s\n",
                    nr_failures, 
                    nr_tests,
                    skipped_message(nr_skipped));
            end

            return tuple(nr_tests, nr_failures, nr_skipped);
        end
    end;

# Helper for random tests

define run_random_test_body(description, body) =
    begin
        i := 0;
        successes := 0;
        target := 100;
        limit := 1000;
        okay := true;

        while okay and successes != target and i < limit do
            result := body();
            if or_else(false, result) then
                successes := successes + 1;
            end
            okay := or_else(true, result);
            i := i + 1;
        end

        if okay and not(successes = target) then
            printf("  ...random test '%s' reached limit %d with only %d successes of target %d",
                description, limit, successes, target);
        end

        if okay and successes = target and i != successes then
            printf("  ...random test '%s' reached target %d in %d steps. Limit is %d.",
                description, target, i, limit);
        end

        if not(okay) then
            printf("  ...random test '%s' failed on step %d after %d successes of target %d. Limit is %d.",
                description, i, successes, target, limit);
        end

        return okay and successes = target;
    end;

# Helper to print the number of skipped tests or suites.

define skipped_message(nr_skipped) =
    if nr_skipped = 0 then
        ""
    else
        format(", %d skipped", nr_skipped)
    end;

# ------------------------------------------------------------------------------
# Catch wrappers
# ------------------------------------------------------------------------------

declare catch_with_fail, catch_with_skip ::
    (() -> Boole) -> Maybe(Boole);

doc catch_with_skip
    "Alias for catch intended for use in random tests. If an error occurs the
    test is skipped.

    See also <code>catch_with_fail</code>.
   
    Temporary stub until better error handling is added.";

define catch_with_skip(f) =
    catch(f);

doc catch_with_fail
    "Wrapper around catch intended for use in random tests. If an error occurs the
    test fails.
   
    See also <code>catch_with_skip</code>.

    Temporary stub until better error handling is added.";

define catch_with_fail(f) = 
    just(or_else(false, catch(f)));
