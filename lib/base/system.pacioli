export
    _three_question_marks,
    _skip,
    _system_time,
    _asin,
    _acos,
    _atan,
    _atan2,
    _add_mut,
    _precision,
    _set_precision,
    _nr_decimals,
    _set_nr_decimals,
    _num2string;

# ----------------------------------------------------------------------------
# System functions
# ----------------------------------------------------------------------------

declare_primitive _three_question_marks() :: for_type t: () -> t;

# ----------------------------------------------------------------------------

declare_primitive _skip() :: () -> Void;

# ----------------------------------------------------------------------------

doc _system_time
    "Number of milliseconds since some starting point.";

declare_primitive _system_time() :: () -> 1;

# ----------------------------------------------------------------------------

declare_primitive _asin(A) :: for_index P,Q: (P! per Q!) -> P! per Q!;

# ----------------------------------------------------------------------------

declare_primitive _acos(A) :: for_index P,Q: (P! per Q!) -> P! per Q!;

# ----------------------------------------------------------------------------

declare_primitive _atan(A) :: for_index P,Q: (P! per Q!) -> P! per Q!;

# ----------------------------------------------------------------------------

declare_primitive _atan2(A) ::
  for_index P,Q: for_unit a, P!u, Q!v: (a*P!u per Q!v, a*P!u per Q!v) -> P! per Q!;

# ----------------------------------------------------------------------------

declare_primitive _add_mut(list, element) :: for_type a: (List(a), a) -> List(a);

# ----------------------------------------------------------------------------

declare_primitive _set_precision(n) :: (1) -> Void;

# ----------------------------------------------------------------------------

declare_primitive _precision() :: () -> 1;

# ----------------------------------------------------------------------------

declare_primitive _set_nr_decimals(n) :: (1) -> Void;

# ----------------------------------------------------------------------------

declare_primitive _nr_decimals() :: () -> 1;

# ----------------------------------------------------------------------------

declare_primitive _num2string(A, decimals, U) :: for_index I, J: for_unit a, I!u, J!v:
    (a*I!u per J!v, 1, a*I!u per J!v) -> String;
