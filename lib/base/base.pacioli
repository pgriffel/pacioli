include string;
include list;
include array;
include matrix;
include io;
include system;

# ----------------------------------------------------------------------------
# Units
#
# The SI units are defined here to make them available in the standard 
# library. The SI library gives extensions.
# ----------------------------------------------------------------------------

export
    tuple,
    apply,
    identity,
    type_of,
    equal,
    not_equal,
    not,
    error,
    just,
    nothing,
    is_nothing,
    catch;

defunit metre "m";
defunit gram "g";
defunit second "s";
defunit ampere "A";
defunit kelvin "K";
defunit mole "mol";
defunit candela "cd";
defunit hertz "Hz";
defunit people "ppl";

# ----------------------------------------------------------------------------
# General primitives
# ----------------------------------------------------------------------------
 
doc tuple
    "Creates a tuple from the arguments.";

declare_primitive tuple (args) :: for_type t: t -> t;

# ----------------------------------------------------------------------------

doc apply
    "Applies a function to a tuple of arguments.";

declare_primitive apply(fun, tuple) :: for_type s,t: (s -> t, s) -> t;

# ----------------------------------------------------------------------------

doc identity
    "The identity function. Just returns its single argument.";

declare_primitive identity(x) :: for_type t: (t) -> t;

# ----------------------------------------------------------------------------

doc type_of
    "One of 'string', 'matrix' and 'generic'.";

declare_primitive type_of(x) :: for_type t: (t) -> Identifier;

# ----------------------------------------------------------------------------

doc equal
    "Are the given values equal?";

declare_primitive equal(x, y) :: for_type t: (t, t) -> Boole;

# ----------------------------------------------------------------------------

doc not_equal
    "Shorthand for <code>not(equal(x, y))</code>.";

declare_primitive not_equal(x, y) :: for_type t: (t, t) -> Boole;

# ----------------------------------------------------------------------------

doc not
    "Logical complement";

declare_primitive not(x) :: (Boole) -> Boole;

# ----------------------------------------------------------------------------

doc error
    "Signals an error.";

declare_primitive error(message) :: for_type t: (String) -> t;

# ----------------------------------------------------------------------------
# Maybe
# ----------------------------------------------------------------------------

declare_primitive just(x) :: for_type t: (t) -> Maybe(t);

declare_primitive nothing :: for_type t: () -> Maybe(t);

declare_primitive is_nothing(maybe) :: for_type t: (Maybe(t)) -> Boole;

declare_primitive maybe_get(maybe) :: for_type t: (Maybe(t)) -> t;

declare_primitive catch(fun) :: for_type t: (() -> t) -> Maybe(t);