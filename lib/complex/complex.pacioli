#


#---------------------------------------------------------------------------------------------
# neg
#---------------------------------------------------------------------------------------------

declare neg_complex :: for_index P, Q: for_unit a, P!u, Q!v:
    (ComplexMatrix(a, P!u, Q!v)) -> ComplexMatrix(a, P!u, Q!v);

define neg_complex(A) =
    let (re, im) = A
    in
        tuple(-re, -im)
    end;

#---------------------------------------------------------------------------------------------
# row_complex, row_domain_complex, rows_complex
#---------------------------------------------------------------------------------------------

declare row_complex :: for_index C, D: for_unit a, D!b:
    (ComplexMatrix(a, C!, D!b), C) -> ComplexMatrix(a, 1, D!b);

define row_complex(A, r) =
    let (re, im) = A
    in
        tuple(row(re, r), row(im, r))
    end;

declare row_domain_complex :: for_index D, E: for_unit a, D!b, E!c:
    (ComplexMatrix(a, D!b, E!c)) -> List(D);

define row_domain_complex(A) =
    let (re, im) = A
    in
        row_domain(re)
    end;

declare rows_complex :: for_index C, D: for_unit a, D!b:
    (ComplexMatrix(a, C!, D!b)) -> List(ComplexMatrix(a, 1, D!b));

define rows_complex(complex_matrix) = 
  [row_complex(complex_matrix,i) | i <- row_domain_complex(complex_matrix)];

#---------------------------------------------------------------------------------------------
# column_complex, column_domain_complex, columns_complex
#---------------------------------------------------------------------------------------------

declare column_complex :: for_index C, D: for_unit a, C!b:
    (ComplexMatrix(a, C!b, D!), D) -> ComplexMatrix(a, C!b, 1);

define column_complex(A, r) =
    let (re, im) = A
    in
        tuple(column(re, r), column(im, r))
    end;

declare column_domain_complex :: for_index D, E: for_unit a, D!b, E!c:
    (ComplexMatrix(a, D!b, E!c)) -> List(E);

define column_domain_complex(A) =
    let (re, im) = A
    in
        column_domain(re)
    end;

declare columns_complex :: for_index C, D: for_unit a, C!b:
    (ComplexMatrix(a, C!b, D!)) -> List(ComplexMatrix(a, C!b, 1));

define columns_complex(complex_matrix) = 
  [column_complex(complex_matrix,i) | i <- column_domain_complex(complex_matrix)];


declare map_matrix_complex ::
  for_index P,Q: for_unit a,b:
    ((ComplexMatrix(a, 1, 1)) -> ComplexMatrix(b, 1, 1), ComplexMatrix(a, P!, Q!)) -> ComplexMatrix(b, P!, Q!);

define map_matrix_complex(fun, mat) = 
    let (re, im) = mat,
        complex_tuples = [tuple(i, j, fun(tuple(get(re, i, j), get(im, i, j)))) | i <- row_domain(re),
                                                                                  j <- column_domain(re)],
        re_tuples = [tuple(i, j, real) | (i, j, c) <- complex_tuples, (real, _) := c],
        im_tuples = [tuple(i, j, imag) | (i, j, c) <- complex_tuples, (_, imag) := c]
    in                                                                        
        tuple(make_matrix(re_tuples), make_matrix(im_tuples))
    end;


doc scale_complex_matrix
    "Scales a complex matrix with some factor.";

declare scale_complex_matrix :: for_index E, F: for_unit a, b, E!c, F!d:
    (a, ComplexMatrix(b, E!c, F!d)) -> ComplexMatrix(a*b, E!c, F!d);

define scale_complex_matrix(c, q) =
  let (r, i) = q in
      tuple(scale(c, r), scale(c, i))
  end;

#
# TODO: make a complex_inverse_matrix
#
doc complex_inverse
    "The inverse of a complex number. complex_product(q, complex_inverse(q)) = 1";

declare complex_inverse ::
    for_unit a: (ComplexMatrix(a, 1, 1)) -> ComplexMatrix(a^-1, 1, 1);

define complex_inverse(c) = 
    let
        (r, i) = c,
        denominator = r^2 + i^2
    in
        tuple(r / denominator, -i / denominator)
    end;

doc complex2str
    "String representation of a complex number with nr_decimals() decimals.";

declare complex2str ::
    for_unit a: (ComplexMatrix(a, 1, 1), a) -> String;

define complex2str(q, u) =
    complex2string(q, nr_decimals(), u);

# ----------------------------------------------------------------------------

doc complex2string
    "String representation of a complex number.";

declare complex2string ::
    for_unit a: (ComplexMatrix(a, 1, 1), decimals, a) -> String;

define complex2string(c, decimals, u) =
    let
        (r, i) = c,
        magnitude_r = num2string(magnitude(r), decimals, 1),
        magnitude_i = num2string(magnitude(i), decimals, 1),       
        unit = unit2string(unit(r)),
        #unit = unit2string(u),
        compl = format("%s + %si", magnitude_r, magnitude_i)
    in
        if unit = "1" then
            compl
        else
            format("(%s)%s", compl, unit)
        end
    end;


declare get_scalar_tuple :: for_unit a: (ComplexMatrix(a, 1, 1)) -> Tuple(a, a);

define get_scalar_tuple(x) =
    let
        (re, im) = x,
        real = get(re, _, _),
        imag = get(im, _, _)
    in
        tuple(real, imag)
    end;

declare make_scalar_complex :: for_unit a: (a, a) -> ComplexMatrix(a, 1, 1);

define make_scalar_complex(re, im) =
    let
        real = make_matrix([tuple(_, _, re)]),
        imag = make_matrix([tuple(_, _, im)])
    in
        tuple(real, imag)
    end;


#
# TODO: make a matrix (elementwise) function.
#
doc unit_complex
    "Scales a complex number to one with norm 1.";

declare unit_complex ::
    for_unit a: (ComplexMatrix(a, 1, 1)) -> ComplexMatrix(1, 1, 1);

define unit_complex(c) =
    scale_complex_matrix(1 / norm_complex(c), c);
