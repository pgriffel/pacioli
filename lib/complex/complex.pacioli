# magnitude_complex(?), scalar_unit(?), row_unit(?), column_unit(?), row_domain, column_domain,
# row, column, get(?), get_num(?), left_identity, right_identity, NO signum (!), support,
# NO positive_ resp negative_support, minus, divide (elementwise), left_divide, expt, mexpt,
# scale, rscale, scale_down, lscale_down, negative(? =neg), reciprocal, dim_inv, dim_div,
# total, NO less(_eq), greater(_eq), is_zero,
