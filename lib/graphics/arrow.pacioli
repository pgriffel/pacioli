# ------------------------------------------------------------------------------
# 3D graphics
# ------------------------------------------------------------------------------

include color;

import geometry;

export
    Arrow,
    make_arrow,
    origin_arrow,
    move_arrow,
    arrow_name,
    arrow_label,
    arrow_color,
    with_arrow_name,
    with_arrow_label,
    with_arrow_color;

# ------------------------------------------------------------------------------
# Arrow
# ------------------------------------------------------------------------------

doc Arrow
    "An arrow is a colored line segment from from one position to another,
    with an arrowhead at the end. Is an element of a <code>Scene(a)</code> 
    scene.";

deftype for_unit a:
    Arrow(a) = Tuple(a*Geom3!, a*Geom3!, String, String, Maybe(Color));

# ------------------------------------------------------------------------------

doc make_arrow
    "Creates an arrow between two points.";

declare make_arrow ::
    for_unit a: (a*Geom3!, a*Geom3!) -> Arrow(a);

define make_arrow(from, to) =
    tuple(from, to, "", "", nothing());

# ------------------------------------------------------------------------------

doc origin_arrow
    "Creates an arrow from the origin to some point.";

declare origin_arrow :: for_unit a: (a*Geom3!) -> Arrow(a);

define origin_arrow(vector) =
    make_arrow(0 '.*' vector, vector);

# ------------------------------------------------------------------------------

doc arrow_name
    "An arrow's name.";

declare arrow_name :: for_unit a: (Arrow(a)) -> String;

define arrow_name(arrow) =
    let (_, _, name, _, _) = arrow in
        name
    end;

# ------------------------------------------------------------------------------

doc arrow_label
    "An arrow's color.";

declare arrow_label :: for_unit a: (Arrow(a)) -> String;

define arrow_label(arrow) =
    let (_, _, _, label, _) = arrow in
        label
    end;

# ------------------------------------------------------------------------------

doc arrow_color
    "An arrow's color.";

declare arrow_color :: for_unit a: (Arrow(a)) -> Maybe(Color);

define arrow_color(arrow) =
    let (_, _, _, _, color) = arrow in
        color
    end;

# ------------------------------------------------------------------------------

doc move_arrow
    "Updates the start and end position of the arrow";

declare move_arrow :: for_unit a: (Arrow(a), a * Geom3!, a * Geom3!) -> Arrow(a);

define move_arrow(arrow, from, to) =
    let (_, _, color, name, label) = arrow in
        tuple(from, to, color, name, label)
    end;

# ------------------------------------------------------------------------------

doc with_arrow_name
    "A copy of the arrow, but with the label.";

declare with_arrow_name ::
    for_unit a: (String, Arrow(a)) -> Arrow(a);

define with_arrow_name(name, arrow) =
    let (from, to, _, label, color) = arrow in
        tuple(from, to, name, label, color)
    end;
# ------------------------------------------------------------------------------

doc with_arrow_label
    "A copy of the arrow, but with the label.";

declare with_arrow_label ::
    for_unit a: (String, Arrow(a)) -> Arrow(a);

define with_arrow_label(label, arrow) =
    let (from, to, name, _, color) = arrow in
        tuple(from, to, name, label, color)
    end;
# ------------------------------------------------------------------------------

doc with_arrow_color
    "Copy of the arrow, but with a different color.";

declare with_arrow_color :: for_unit a: (Color, Arrow(a)) -> Arrow(a);

define with_arrow_color(color, arrow) =
    let (from, to, name, label, _) = arrow in
        tuple(from, to, name, label, just(color))
    end;
