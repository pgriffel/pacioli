# ------------------------------------------------------------------------------
# 3D graphics
# ------------------------------------------------------------------------------

import geometry;

include color;

export
    SpotLight,
    make_spotlight;

# ------------------------------------------------------------------------------
# SpotLight
# ------------------------------------------------------------------------------

doc SpotLight
    "A spotlight. Is an element of a <code>Scene(a, Geom3!u)</code> scene.";

deftype for_unit a, Geom3!u:
    SpotLight(a, Geom3!u) = Tuple(a * Geom3!u, a * Geom3!u, Color, candela);

# ------------------------------------------------------------------------------

doc make_spotlight
    "Constructs a spotlight.";

declare make_spotlight ::
    for_unit a, Geom3!u: (a * Geom3!u, a * Geom3!u, Color, candela) -> SpotLight(a, Geom3!u);

define make_spotlight(position, target, color, intensity) =
    tuple(position, target, color, intensity);
