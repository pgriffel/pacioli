# ------------------------------------------------------------------------------
# 3D graphics
# ------------------------------------------------------------------------------

import geometry;

include color;

export
    Path,
    make_path,
    make_line,
    with_path_color;

# ------------------------------------------------------------------------------
# Path
# ------------------------------------------------------------------------------

doc Path
    "A series of lines between succesive points. Is an element of a 
    <code>Scene(a)</code> scene.";

deftype for_unit a:
    Path(a) = Tuple(List(a * Geom3!), Color);

# ------------------------------------------------------------------------------

doc make_path
    "Constructs a path from a list of points.";

declare make_path ::
    for_unit a: (List(a * Geom3!)) -> Path(a);

define make_path(vecs) =
    tuple(vecs, make_color("blue"));

# ------------------------------------------------------------------------------

doc make_line
    "A line between two points. Each point is indicated by a vector.";

declare make_line ::
    for_unit a: (a * Geom3!, a * Geom3!) -> Path(a);

define make_line(v0, v1) =
    make_path([v0, v1]);

# ------------------------------------------------------------------------------

declare with_path_color ::
    for_unit a: (Path(a), Color) -> Path(a);

define with_path_color(path, color) =
    let (vecs, _) = path in
        tuple(vecs, color)
    end;