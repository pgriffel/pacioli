# ------------------------------------------------------------------------------
# 3D graphics
# ------------------------------------------------------------------------------

import geometry;

include color;

export
    Path,
    make_path,
    make_line,
    with_path_color;

# ------------------------------------------------------------------------------
# Path
# ------------------------------------------------------------------------------

doc Path
    "A series of lines between succesive points. Is an element of a 
    <code>Scene(a, Geom3!u)</code> scene.";

deftype for_unit a, Geom3!u:
    Path(a, Geom3!u) = Tuple(List(a * Geom3!u), Color);

# ------------------------------------------------------------------------------

doc make_path
    "Constructs a path from a list of points.";

declare make_path ::
    for_unit a, Geom3!u: (List(a * Geom3!u)) -> Path(a, Geom3!u);

define make_path(vecs) =
    tuple(vecs, make_color("blue"));

# ------------------------------------------------------------------------------

doc make_line
    "A line between two points. Each point is indicated by a vector.";

declare make_line ::
    for_unit a, Geom3!u: (a * Geom3!u, a * Geom3!u) -> Path(a, Geom3!u);

define make_line(v0, v1) =
    make_path([v0, v1]);

# ------------------------------------------------------------------------------

declare with_path_color ::
    for_unit a, Geom3!u: (Path(a, Geom3!u), Color) -> Path(a, Geom3!u);

define with_path_color(path, color) =
    let (vecs, _) = path in
        tuple(vecs, color)
    end;