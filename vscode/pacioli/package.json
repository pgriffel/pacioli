{
  "name": "pacioli",
  "displayName": "Pacioli",
  "description": "The Pacioli language",
  "version": "0.0.0",
  "publisher": "PRG",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pacioli",
        "aliases": [
          "pacioli",
          "pacioli"
        ],
        "extensions": [
          "pacioli"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pacioli",
        "scopeName": "pacioli",
        "path": "./syntaxes/pacioli.tmLanguage.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "pacioli",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The pacioli compiler command to execute. Valid Pacioli compiler commands are 'run', 'compile', 'types', 'symbols', 'api', and 'baseapi'."
          },
          "target": {
            "type": "string",
            "description": "The target for the compile command. One of 'mvm', 'javascript', 'matlab', or 'python'"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "pacioli.run",
        "title": "Pacioli run"
      },
      {
        "command": "pacioli.types",
        "title": "Pacioli types"
      },
      {
        "command": "pacioli.compilejs",
        "title": "Pacioli compile to js"
      },
      {
        "command": "pacioli.compilemvm",
        "title": "Pacioli compile to mvm"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == pacioli",
          "submenu": "pacioli.compile",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == pacioli",
          "command": "pacioli.types",
          "group": "navigation"
        },
        {
          "when": "resourceLangId == pacioli",
          "command": "pacioli.run",
          "group": "navigation"
        }
      ],
      "pacioli.compile": [
        {
          "command": "pacioli.compilejs",
          "group": "navigation"
        },
        {
          "command": "pacioli.compilemvm",
          "group": "navigation"
        }
      ]
    },
    "submenus": [
      {
        "id": "pacioli.compile",
        "label": "Pacioli compile"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+f9",
        "command": "workbench.action.tasks.runTask",
        "args": "pacioli: Run pacioli file"
      },
      {
        "key": "ctrl+f10",
        "command": "workbench.action.tasks.runTask",
        "args": "pacioli: Types pacioli file"
      },
      {
        "key": "ctrl+f11",
        "command": "workbench.action.tasks.runTask",
        "args": "pacioli: Compile pacioli file to js"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
