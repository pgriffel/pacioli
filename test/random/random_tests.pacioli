import testing;
import random;

run_test_suites(random_sampling_suites);

define random_sampling_suites = [
    shuffle_suite
];

define shuffle_suite = test_suite("Function shuffle", [
    test("should give the emtpy array for n = 0", () -> 
        shuffle([]) = []),

    test("should give a singleton array for n = 1", () -> 
        shuffle(["foo"]) = ["foo"]),

    test("should give only valid numbers when shuffling naturals", () -> 
        let n = 5, nats = naturals(n), shuffled = shuffle(nats) in
            all[contains(nats, i) | i <- shuffled]
        end),

    test("should give all valid numbers when shuffling naturals", () -> 
        let n = 5, nats = naturals(n), shuffled = shuffle(nats) in
            all[contains(shuffled, i) | i <- nats]
        end),

    test("should be uniformly distributed", () -> 
        begin
            n := 5;
            k := 10000;
            treshold := 0.05;

            expected := (n-1)/2;
            shuffled := shuffle(naturals(n));
            total := shuffled;
            i := 1;
            while i < k do
                shuffled := shuffle(shuffled);
                total := zip_with(sum, total, shuffled);
                i := i + 1;
            end
            return all[err < treshold | val <- total,
                                        avg := val / k,
                                        err := abs(avg - expected)];
        end)
]);
