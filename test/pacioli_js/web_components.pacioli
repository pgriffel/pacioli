defindex Continent = {
    Africa,
    Asia,
    Europe,
    North_America,
    South_America,
    Antarctica,
    Oceania 
};

define earth_surface_area = c1 * c1 * 510064472 * |kilo:metre|^2;

define earth_land_area = c1 * c1 * total(land_area);

define earth_land_area_fraction = 
    to_percentage(earth_land_area / earth_surface_area);
    

