define scattered(n) =
  tuple(randomNatVec(100), randomNatVec(200));

define scattered_lists(n) =
    unzip([tuple(a * |gram|, b * |gram|) | _ <- naturals(n), 
                                           a := floor(6 * random()), 
                                           b := floor(6 * random())]);

# ------------------------------------------------------------------------------

define dice(n, k) =
    [sum[1 + floor(6 * random()) | _ <- naturals(k)] | _ <- naturals(n)];

# ------------------------------------------------------------------------------

define test_data_dimless =
    sines(ceiling(random() * 200), ceiling(random() * 25));

define test_data_metre = [5000 * x * |metre| | x <- test_data_dimless];

define sines(n, k) =
    [v | cs := [ tuple(j, random() - 0.5, random() - 0.5) | j <- naturals(k)],
         arc := 2 * pi / n * |radian|,
         decay := 1.2,
         i <- naturals(n),
         v := 0 + sum[ w | (j, c1, c2) <- cs,
                       d := expt(decay, j + 1),
                       w := (c1 / d) * sin(i * (j + 1) * arc) + (c2 / d) * cos(i * (j + 1) * arc)]];

