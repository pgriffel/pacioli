import si;
import geometry;
import geometric_algebra;
import graphics;

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------

define second(x) =
    let (_,a) = x in a end;

define nth_tail(xs, n) = 
  begin
    tailed := xs;
    i := n;
    while i > 0 do
        tailed := tail(tailed);
        i := i - 1;
    end
    return tailed;
  end;

# ------------------------------------------------------------------------------
# Chart data
# ------------------------------------------------------------------------------

define NR_NATS = 100;

defindex Nats = [pad_left(num2string(n, 0, |1|), 2, "0") | n <- naturals(NR_NATS)];

define natVec(nums) = 
    make_matrix([x | (n, v) <- zip(row_domain(|Nats!|), nums), 
                      x := tuple(n, _,  100 * random() * random() * random() * random())]);

# ------------------------------------------------------------------------------

define wordcloud() = [
    tuple("foo", 112),
    tuple("bar", 23),
    tuple("bax", 42)   
];

# ------------------------------------------------------------------------------

define scattered(n) =
  tuple(natVec(naturals(NR_NATS)), natVec(naturals(NR_NATS)));

define scattered_lists(n) =
    unzip([tuple(a * |gram|, b * |gram|) | _ <- naturals(n), 
                                           a := floor(6 * random()), 
                                           b := floor(6 * random())]);

# ------------------------------------------------------------------------------

define dice(n, k) =
    [sum[1 + floor(6 * random()) | _ <- naturals(k)] | _ <- naturals(n)];

# ------------------------------------------------------------------------------

define test_data_dimless() =
    sines(50, 5);

define test_data_dimless2 =
    sines(ceiling(random() * 500), ceiling(random() * 100));

define test_data_gram2 = [x * |gram| | x <- test_data_dimless2];

define sines(n, k) =
    [v | cs := [ tuple(j, random() - 0.5, random() - 0.5) | j <- naturals(k)],
         arc := 2 * pi / n * |radian|,
         decay := 1.2,
         i <- naturals(n),
         v := 0 + sum[ w | (j, c1, c2) <- cs,
                       d := expt(decay, j + 1),
                       w := (c1 / d) * sin(i * (j + 1) * arc) + (c2 / d) * cos(i * (j + 1) * arc)]];

#define test_data_dimless() = [1,2,3,4,5,6,7,5,6,7,8,6,4,7,8,8,7,76,6,7];

define test_data_gram() = [x * |gram| | x <- test_data_dimless()];

