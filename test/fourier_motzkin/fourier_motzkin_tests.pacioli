import si;
import testing;

import fourier_motzkin;

# ------------------------------------------------------------------------------
# The test suite
# ------------------------------------------------------------------------------

run_test_suites(fourier_motzkin_suites);

declare fourier_motzkin_suites :: List(TestSuite);

define fourier_motzkin_suites = [
    fourier_motzkin_suite
];

# ------------------------------------------------------------------------------
# Test model
# ------------------------------------------------------------------------------

defindex Place = {
    "place a",
    "place b",
    "place c" 
};

defindex Transition = {
    "Transition x",
    "Transition y",
    "Transition z"
};

define tvec(x, y, z) = 
  x '.*' delta(Transition@"Transition x") +
  y '.*' delta(Transition@"Transition y") +
  z '.*' delta(Transition@"Transition z");

defmatrix test_matrix :: Place! per Transition! = {
    "place a", "Transition x" -> 1,
    "place a", "Transition y" -> -1
};

define SIZE = 10;  # Increase for performance test

defindex Left = [format("p%d", i) | i <- naturals(SIZE)];
defindex Right = [format("t%d%s", i, d) | i <- naturals(SIZE), d <- ["_c", "_d", "_k"]];

define foo =
    make_matrix([tuple(nth(i, row_dom), nth(3*i+j, col_dom), v) | 
                    row_dom := row_domain(|Left!|),
                    col_dom := row_domain(|Right!|),
                    i <- naturals(SIZE),
                    j <- [0,1],
                    v := if j = 0 then 1 else -1 end]);

define circ_c = 
    make_matrix([tuple(nth(i, row_dom), nth(3*i+j, col_dom), v) |
                    row_dom := row_domain(|Left!|),
                    col_dom := row_domain(|Right!|),
                    i <- naturals(SIZE),
                    j <- [2],
                    v := -1]);

define circ_d =
    make_matrix([tuple(nth(mod(i+1, SIZE), row_dom), nth(3*i+j, col_dom), v) |
                    row_dom := row_domain(|Left!|),
                    col_dom := row_domain(|Right!|),
                    i <- naturals(SIZE), 
                    j <- [2],
                    v := 1]);

define mat = foo + circ_c + circ_d;

# ------------------------------------------------------------------------------
# Tests
# ------------------------------------------------------------------------------

define fourier_motzkin_suite = test_suite("Function fourier_motzkin", [

    test("should solve correctly for a 3 by 3 matrix with 2 non-zero entries", () ->
        fourier_motzkin(test_matrix) = [tvec(0,0,1), tvec(1,1,0)]
    ),

    test("should solve correctly for the zero matrix", () ->
        fourier_motzkin(0 '.*' test_matrix) = [tvec(1,0,0), tvec(0,1,0), tvec(0,0,1)]
    ),

    test("should solve correctly for 1 by 1 matrices", () ->
        fourier_motzkin(0) = [1] and
        fourier_motzkin(1) = [] and
        fourier_motzkin(9) = [] and
        fourier_motzkin(-9) = []
    ),

    test("should solve correctly for the foo matrix", () ->
        list_size(fourier_motzkin(mat)) = SIZE^2 + 1
    )
]);
