define qr_suite = test_suite("Function qr", [
   
    random_test("should be a proper factorization", () ->
        let
            # Doesn't make the default 14 decimals
            precision = 10*|decimals|,
            A = random_4_by_4_matrix(),
            (Q, R) = qr_decomposition(A)
        in
            just(approximates(A, Q '*' R, precision))
        end),

    random_test("should give an upper triangular R", () ->
        let
            (_, R) = qr_decomposition(random_4_by_4_matrix())
        in
            just(is_upper_trianular(R))
        end),

    random_test("should give an orthonormal Q", () ->
        let
            A = random_4_by_4_matrix(),
            I = left_identity(A),
            (Q, _) = qr_decomposition(A)
        in
            just(Q '*' Q^T ~= I and Q^T '*' Q ~= I)
        end)
]);

