 # [[0.42025926416976755, 2.3909100543095816, -2.8223938905329136], [-1.1899934796618081, -6.770028926565032, 7.991805566515104], [-1.0075396878008331, -5.732025383040305, 6.766475130384711], [0.8826604407841495, 5.02157097376835, -5.927806113699193]]

doc svd_reg
    "Fails in numeric javascript (JAMA version is okay), succeeds in mvm.";

defmatrix svd_reg :: Four!unit per Three!unit = {
    one, one -> 0.42025926416976755,
    one, two -> 2.3909100543095816,
    one, three -> -2.8223938905329136,
    two, one -> -1.1899934796618081,
    two, two -> -6.770028926565032,
    two, three -> 7.991805566515104,
    three, one -> -1.0075396878008331,
    three, two -> -5.732025383040305,
    three, three -> 6.766475130384711,
    four, one -> 0.8826604407841495,
    four, two -> 5.02157097376835,
    four, three -> -5.927806113699193
};

# ------------------------------------------------------------------------------

define print_svd(A) =
    let
        precision = 14*|decimals|,
        outcome = catch(() -> singular_value_list(A))
    in
        begin
            printf("A=%.30f", A);
            if is_error(outcome) then 
                printf("error: %s", result_error(outcome));
            else
                triples := result_value(outcome); 

                max_s := max[s | (s, _, _) <- triples];
                min_s := min[s | (s, _, _) <- triples];

                condition_number := max_s / min_s;

                result := approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- triples], precision);

                printf("%nCondition number: %.5f, svd correct=%s, precision=%d", condition_number, result, precision);
                
                for (s, v, w) <- triples do
                    printf("%nSingular value: %.30f", s);
                    printf("Left singular vector: %n%.30f", v);
                    printf("Right singular vector: %n%.30f", w);
                    printf("Diff: %n%.30f", A - sum[a '.*' v '*' w^T | (a,v,w) <- triples]);
                end
                printf("Sum %n%.30f", sum[a '.*' v '*' w^T | (a,v,w) <- triples]);
                printf("Diff: %n%.30f", A - sum[a '.*' v '*' w^T | (a,v,w) <- triples]);
                
            end            
        end
    end;

# ------------------------------------------------------------------------------

define svd_suite(description, matrix_generator, precision) = test_suite(description, [

    random_test("should be a proper factorization the matrix", () ->
        let A = matrix_generator() in
            just(approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- singular_value_list(A)], precision))
        end),

    random_test("should give non-negative singular values", () ->
        just(all[magnitude(s) >= 0 | (s, _, _) <- singular_value_list(matrix_generator())])),

    random_test("should give an orthogonal set for the row dimension", () ->
        just(pairwise_orthogonal_magnitudes([v | (_, v, _) <- singular_value_list(matrix_generator())], precision))),
                
    random_test("should give an orthogonal set for the column dimension", () ->
        just(pairwise_orthogonal_magnitudes([w | (_, _, w) <- singular_value_list(matrix_generator())], precision)))
]);

# ------------------------------------------------------------------------------

doc pairwise_orthogonal_magnitudes
    "Not a true orthogonal set, just orthogonality of the magnitudes.";

declare pairwise_orthogonal_magnitudes ::
    for_index B: for_unit a, B!u: (List(a*B!u), decimals) -> Boole;

define pairwise_orthogonal_magnitudes(vs, precision) =
    let 
        indexed = zip(naturals(list_size(vs)), [magnitude(v) | v <- vs])
    in
        all[approximates(inner(v, w), if i = j then 1 else 0 end, precision) | 
            (i, v) <- indexed,
            (j, w) <- indexed]
    end;

