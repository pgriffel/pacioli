# ------------------------------------------------------------------------------
# Index elements suite
# ------------------------------------------------------------------------------

defindex Foo = {foo, bar, baz};

defmatrix foo :: metre * Foo! = {
   foo -> 12,
   bar -> 13
};

define index_element_suite = test_suite("Index element", [
    
    test("should do something", () ->
        get(foo, Foo@foo, _) = 12*|metre|),
         
   test("should work with row_domain", () ->
        [get(foo, x, _) | x <- row_domain(foo)] = [12*|metre|, 13*|metre|, 0*|metre|]),

   test("should work with row_domain and assignment", () ->
        [value | x <- row_domain(foo), value := get(foo, x, _)] = [12*|metre|, 13*|metre|, 0*|metre|]),
         
   test("should work with column_domain", () ->
        [get(foo^T, _, y) | y <- column_domain(foo^T)] = [12*|metre|, 13*|metre|, 0*|metre|]),

   test("should work with column_domain and assignment", () ->
        [value | y <- column_domain(foo^T), value := get(foo^T, _, y)] = [12*|metre|, 13*|metre|, 0*|metre|]),
         
   test("should print test", () ->
        begin print_test(); return "foo"; end = "foo")
]);

# ------------------------------------------------------------------------------
# Index elements suite
# ------------------------------------------------------------------------------

define format_suite = test_suite("Function format", [
    
    test("should format empty string", () ->
        format("") = ""),
         
    test("should format %s with a string", () ->
        format("prefix%ssuffix", "foo") = "prefixfoosuffix"),
      
    test("should format %d with a dimensionless number", () ->
        format("prefix%dsuffix", 12) = "prefix12suffix"),   

    test("should format %10d with a dimensionless number", () ->
        format("prefix%10dsuffix", 12) = "prefix        12suffix"),   

    test("should format %10d with a dimensioned number", () ->
        format("prefix%10dsuffix", 12 * |metre|) = "prefix       12msuffix" or
        (is_js and format("prefix%10dsuffix", 12 * |metre|) = "prefix        12suffix")),   

    test("should format %f with a dimensionless number", () ->
        format("prefix%fsuffix", 12) = "prefix12,00suffix" or
        format("prefix%fsuffix", 12) = "prefix12.00suffix"),   

    test("should format %7.3f with a dimensionless number", () ->
        format("prefix%7.3fsuffix", 12) = "prefix 12,000suffix" or
        format("prefix%7.3fsuffix", 12) = "prefix 12.000suffix"),   

    test("should format %7.3f with a dimensioned number", () ->
        format("prefix%17.3fsuffix", 12 * |metre/second^2|) = "prefix      12,000m/s^2suffix" or
        (is_js and format("prefix%17.3fsuffix", 12 * |metre/second^2|) = "prefix           12.000suffix")),   

    test("should error on not number for %f", () ->
        is_nothing(catch(() -> format("%f", "foo")))),   

    test("should error on not number for %d", () ->
        is_nothing(catch(() -> format("%d", "foo")))),   
         
    test("should error on trailing percentage character", () ->
         is_nothing(catch(() -> format("%"))))
]);

declare print_test :: () -> Void;

define print_test() =
   print(format("Testing %s", Foo@foo));

declare is_js :: Boole;

define is_js = format("%d", |metre|) = "1";

# ------------------------------------------------------------------------------
# Function plu
# ------------------------------------------------------------------------------

define plu_suite = 
    if is_js then
        test_suite("No plu for pacioli-js", [])
    else
        real_plu_suite
    end;

define real_plu_suite = test_suite("Function plu", [

    random_test("should be a proper factorization", () ->
        catch_with_skip(() ->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,

                A = random_4_by_4_matrix(),
                (P, L, U) = plu(A)
            in
                approximates(P '*' A, L '*' U, precision)
            end)),

    random_test("should give upper triangular U", () ->
        catch_with_skip(() ->
            let (_, _, U) = plu(random_4_by_4_matrix()) in
                is_upper_trianular(U)
            end)),

    random_test("should give lower triangular L", () ->
        catch_with_skip(() ->
            let (_, L, _) = plu(random_4_by_4_matrix()) in
                is_lower_trianular(L)
            end)),

    random_test("should give permutation matrix P", () ->
        catch_with_skip(() ->
            let 
                A = random_4_by_4_matrix(),
                (P, _, _) = plu(A)
            in
                # TODO: proper test
                P '*' P^T = left_identity(A)
            end))
]);

# ------------------------------------------------------------------------------
# Function qr
# ------------------------------------------------------------------------------

define qr_suite = 
    if is_js then
        test_suite("No qr for pacioli-js", [])
    else
        real_qr_suite
    end;

define real_qr_suite = test_suite("Function qr", [
   
    random_test("should be a proper factorization", () ->
        catch_with_skip(() ->
            let
                # Doesn't make the default 14 decimals
                precision = 10*|decimals|,
                A = random_4_by_4_matrix(),
                (Q, R) = qr(A)
            in
                approximates(A, Q '*' R, precision)
            end)),

    random_test("should give an upper triangular R", () ->
        catch_with_skip(() ->
            let
                (_, R) = qr(random_4_by_4_matrix())
            in
                is_upper_trianular(R)
            end)),

    random_test("should give an orthonormal Q", () ->
        catch_with_skip(() ->
            let
                A = random_4_by_4_matrix(),
                I = left_identity(A),
                (Q, _) = qr(A)
            in
                Q '*' Q^T ~= I and Q^T '*' Q ~= I
            end))
]);

# ------------------------------------------------------------------------------
# Function svd
# ------------------------------------------------------------------------------

define scalar_svd_suite =
    svd_suite("svd for dimensionless scalars", random_1_by_1_matrix, 10*|decimals|);

define uniform_svd_suite =
    svd_suite("svd for dimensionless matrices", random_4_by_3_matrix, 10*|decimals|);

define dimensioned_svd_suite =
    svd_suite("svd for dimensioned matrices", () -> random_4_by_3_matrix() * |Four!unit per Three!unit|, 10*|decimals|);

# ------------------------------------------------------------------------------

define svd_suite(description, matrix_generator, precision) = test_suite(description, [

    random_test("should be a proper factorization the matrix", () ->
        tmp_catch(()->
            let
                A = matrix_generator()
            in
                approximates(A, sum[a '.*' v '*' w^T | (a,v,w) <- svd(A)], precision)
            end)),

    random_test("should give non-negative singular values", () ->
        tmp_catch(()-> all[magnitude(s) >= 0 | (s, _, _) <- svd(matrix_generator())])),

    random_test("should give an orthogonal set for the row dimension", () ->
        tmp_catch(()-> is_weak_orthogonal_set([v | (_, v, _) <- svd(matrix_generator())]))),
                
    random_test("should give an orthogonal set for the column dimension", () ->
        tmp_catch(()-> is_weak_orthogonal_set([w | (_, _, w) <- svd(matrix_generator())])))
]);

# ------------------------------------------------------------------------------

doc is_weak_orthogonal_set
    "Not a true orthogonal set, just orthogonality of the magnitudes.";

declare is_weak_orthogonal_set ::
    for_index B: for_unit a, B!u: (List(a*B!u)) -> Boole;

define is_weak_orthogonal_set(vs) =
    all[inner(magnitude(nth(i, vs)), magnitude(nth(j, vs))) ~= if i = j then 1 else 0 end | 
            nats := naturals(list_size(vs)),
            i <- nats,
            j <- nats];

# ------------------------------------------------------------------------------

# The js version produces NaN numbers for some test cases. For now this is checked
# and an error is thrown. The Java version doesn't throw errors for these cases.
# Therefore the js variant requires a catch_with_skip and the Java variant a
# catch_with_fail. The tmp_catch function is a convenience function to make that
# distinction, until this is addressed.

declare tmp_catch :: (() -> Boole) -> Maybe(Boole);

define tmp_catch(f) = 
    if _is_js then catch_with_skip(f) else catch_with_fail(f) end;

# ------------------------------------------------------------------------------
# Function solve
# ------------------------------------------------------------------------------

define solve_suite = test_suite("Function solve", [

    random_test("should solve ax=b", () ->
        tmp_catch(() ->
            let
                a = random(),
                b = random(),
                x = solve(a, b)
            in
                a '*' x ~= b
            end)),
   
    random_test("should solve AX=B for square matrices", () ->
        tmp_catch(() ->
            let
                # Doesn't make the default 14 decimals
                precision = 8*|decimals|,

                A = random_4_by_4_matrix(),
                B = random_4_by_4_matrix(),
                X = solve(A, B)
            in
                approximates(A^T '*' A '*' X, A^T '*' B, precision)
            end)),
    
    random_test("should solve AX=B when nr column < nr rows", () ->
        tmp_catch(() ->
            let
                # Doesn't make the default 14 decimals
                precision = 8*|decimals|,

                A = random_4_by_3_matrix(),
                B = random_4_by_3_matrix(),
                X = solve(A, B)
            in
                approximates(A^T '*' A '*' X, A^T '*' B, precision)
            end)),

    # The javascript version leads sometimes to NaN numbers in the result vectors of $base_matrix_svd. The svd 
    # function causes problems.
    #
