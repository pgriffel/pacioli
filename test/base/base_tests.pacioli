define scalar_inverse_suite =
    inverse_suite("inverse for dimensionless scalars", random_1_by_1_matrix, 5*|decimals|);

define matrix_inverse_suite =
    inverse_suite("inverse for matrices", () -> random_4_by_4_matrix() * |metre * Four!unit per Four!unit|, 5*|decimals|);

# ------------------------------------------------------------------------------

define inverse_suite(description, matrix_generator, precision) = test_suite(description, [

    random_test("should satisfy A = A '*' inverse(A) '*' A", () ->
        let
            A = matrix_generator(),
            A_inv = inverse(A)
        in
            just(approximates(A, A '*' A_inv '*' A, precision))
        end),
    
    random_test("should satisfy inverse(A) = inverse(A) '*' A '*' inverse(A)", () ->
        let
            A = matrix_generator(),
            A_inv = inverse(A)
        in
            just(approximates(A_inv, A_inv '*' A '*' A_inv, precision))
        end),
    
    random_test("should satisfy (inverse(A) '*' A)^T = inverse(A) '*' A", () ->
        let
            A = matrix_generator(),
            A_inv = inverse(A)
        in
            just(is_symmetric(A_inv '*' A, precision))
        end),
    
    random_test("should satisfy (A '*' inverse(A))^T = A '*' inverse(A)", () ->
        let
            A = matrix_generator(),
            A_inv = inverse(A)
        in
            just(is_symmetric(A '*' A_inv, precision))
        end)
]);

define is_symmetric(A, decimals) =
    approximates(magnitude(A^T), magnitude(A), decimals);

