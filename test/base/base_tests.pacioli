define eigenvalue_decomposition_suite = test_suite("Function eigenvalue_decomposition", [

    random_test("should be a proper factorization", () ->
        let
            # Doesn't make the default 14 decimals
            precision = 9*|decimals|,

            A = random_4_by_4_matrix()
        in
            let (D, V) = eigenvalue_decomposition(A) in
                just(approximates(A '*' V, V '*' D, precision))
            end
        end)
]);

define eigenvalue_list_suite = test_suite("Function eigenvalue_list", [

    random_test("should give real eigenvalues and eigenvectors for symmetric matrices", () ->
        let
            # Doesn't make the default 14 decimals
            precision = 10*|decimals|,

            A = symmetric_matrix_generator(random_4_by_4_matrix)()
        in
            just(all[ i ~= 0 | (_, i, _) <- eigenvalue_list(A)])
        end),
         
    random_test("should give correct real eigenvalues and eigenvectors for symmetric matrices", () ->
        let
            # Doesn't make the default 14 decimals
            precision = 10*|decimals|,

            A = symmetric_matrix_generator(random_4_by_4_matrix)()
        in
            let 
                ts = eigenvalue_list(A)
            in
                just(all[ approximates(A '*' v, r '.*' v, precision) | (r, _, v) <- eigenvalue_list(A)])
            end
        end)
]);

# ------------------------------------------------------------------------------

declare symmetric_matrix_generator :: for_index I: for_unit a, I!u:
    (() -> a/I!u per I!u) -> () -> a/I!u per I!u;

doc symmetric_matrix_generator
    "Turns a function that generates matrices into a function that generates
    symmetric matrices.";

define symmetric_matrix_generator(matrix_generator) =
    () ->
        let r = matrix_generator() in
            r^T + r 
        end;

