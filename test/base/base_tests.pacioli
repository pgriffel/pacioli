define sort_suite = test_suite("Function sort", [
    
    test("should sort ascending", () ->
        sort_list([1, 9, 3, 2, 5], (x, y) -> x - y) = [1, 2, 3, 5, 9]),
            
    test("should sort decending", () ->
        sort_list([1, 9, 3, 2, 5], (x, y) -> y - x) = [9, 5, 3, 2, 1])
]);

