# ------------------------------------------------------------------------------
# substring suite
# ------------------------------------------------------------------------------


define substring_suite = test_suite("Function substring", [

    test("should give the empty string when called with indices zero and minus one", () ->
        let str = "abc" in
            substring(str, 0, -1) = ""
        end),

    test("should give the empty string when called with indices zero and zero", () ->
        let str = "abc" in
            substring(str, 0, 0) = ""
        end),

    test("should give the original string when called with zero and string_length", () ->
        let str = "abc" in
            substring(str, 0, string_length(str)) = str
        end),

    test("should give the empty string when called with string_length and string_length", () ->
        let str = "abc" in
            substring(str, string_length(str), string_length(str)) = ""
        end),
        
    test("should give the first character of a string when called with zero and one", () ->
        let
            first_char = "a",
            str = concatenate(first_char, "bc")
        in
            substring(str, 0, 1) = first_char
        end),
        
    test("should give the first character of a string when called with string_length and string_length + 1", () ->
        let
            first_char = "a",
            str = concatenate(first_char, "bc")
        in
            substring(str, string_length(str), string_length(str) + 1) = first_char
        end),

    test("should give the last character of a string when called with string_length - 1 and string_length", () ->
        let
            last_char = "c",
            str = concatenate("ab", last_char)
        in
            substring(str, string_length(str) - 1, string_length(str)) = last_char
        end),

    test("should give the last character of a string when called with minus one and zero", () ->
        let str = "abc" in
            substring(str, -1, 0) = "c"
        end),

    test("should double the string when called with zero and double string_length", () ->
        let str = "abc" in
            substring(str, 0, 2 * string_length(str)) = concatenate(str, str)
        end),

    test("should permutate first char to end when called with 1 and string_length + 1", () ->
        let 
            char = "a",
            rest = "bc",
            str = concatenate(char, rest)
        in
            substring(str, 1, string_length(str) + 1) = concatenate(rest, char)
        end),

    test("should permutate last char to begin when called with -1 and string_length - 1", () ->
        let 
            char = "c",
            rest = "ab",
            str = concatenate(rest, char)
        in
            substring(str, -1, string_length(str) - 1) = concatenate(char, rest)
        end),

    random_test("should give a string of the right size", () ->
        let
            n = random_nat(10),
            str = random_string(n),
            startPos = random_nat(10) - 5,
            endPos = random_nat(10) - 5,

            substr = substring(str, startPos, endPos)
        in
            if n = 0 then
                just(string_length(substr) = 0)
            else
                just(string_length(substr) = max(0, endPos - startPos))
            end
        end),
        
    random_test("should give a string with the right contents", () ->
        let
            n = random_nat(10),
            str = random_string(n),
            startPos = random_nat(10) - 5,
            endPos = random_nat(10) - 5,

            substr = substring(str, startPos, endPos)
        in
            if n = 0 then
                just(substr = "")
            else
                just(all[char_at(substr, i) = char_at(str, mod(startPos + i, n)) | i <- naturals(string_length(substr))])
            end
        end)
]);

define random_string(n) =
    concat[random_char() | _ <- naturals(n)];

define random_char() =
    let chars = ["a", "b", "c", "d", "e"] in
        nth(random_nat(list_size(chars)), chars)
    end;

