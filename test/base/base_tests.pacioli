define max_suite = test_suite("Function max", [
    
    test("should give the vector for two identical vectors",
         () ->
            max(test_vec(0, 4, 0, 7, 10, 0), test_vec(0, 4, 0, 7, 10, 0)) = test_vec(0, 4, 0, 7, 10, 0)
