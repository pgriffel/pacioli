   indexing_suite,
   comprehensions_suite,
   sort_suite,
   reverse_suite,
   nth_suite,
   top_suite,
   bottom_suite,
   total_suite,
   #ranking_suite,   does not exist in MVM yet
   min_suite,
   max_suite,
   tan_suite,
   expt_suite,
   mexpt_suite,
   random_suite,
   equal_suite,
   pad_suite,
   pad_left_suite,
   pad_right_suite,
   index_element_suite,
   format_suite,
   plu_suite,
   svd_suite,
   qr_suite,
   solve_suite
   #mapnz_suite       does not exist in MVM yet
   #kronecker_suite   TODO port in pacioli-ts
];

run_test_suites(base_suites); 

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------

define is_upper_trianular(A) = 
    all[ get_num(A, i, j) = 0 |
        i <- row_domain(A),
        j <- column_domain(A),
        index_less(j, i)];

define is_lower_trianular(A) = 
    all[ get_num(A, i, j) = 0 |
        i <- row_domain(A),
        j <- column_domain(A),
        index_less(i, j)];

# ------------------------------------------------------------------------------
# Random test data
# ------------------------------------------------------------------------------

defindex Three = {one, two, three};

defunit Three!unit = {
    one: metre,
    two: metre,
    three: metre^2
};

define three_vector(one, two, three) =
   make_matrix([
      tuple(Three@one, _, one),
      tuple(Three@two, _, two), 
      tuple(Three@three, _, three)
   ]);

define random_three_vector() = 
    let r() = random() * pick([-3,0,3]) in
        three_vector(r(), r(), r())
    end;

define random_three_vectors =
    [random_three_vector() | _ <- naturals(100)];

define random_three_dim_vectors =
    [random_three_vector() * |Three!unit| | _ <- naturals(100)];

# ------------------------------------------------------------------------------

defindex Four = {one, two, three, four};

defunit Four!unit = {
    one: metre,
    two: metre,
    four: metre^2
};

define four_vector(one, two, three, four) =
   make_matrix([
      tuple(Four@one, _, one),
      tuple(Four@two, _, two), 
      tuple(Four@three, _, three),
      tuple(Four@four, _, four)
   ]);

declare random_four_vector :: () -> Four!;

define random_four_vector() = 
    let r() = random() * pick([-3,0,3]) in
        four_vector(r(), r(), r(), r())
    end;

define random_4_by_4_matrix() =
   sum[random_four_vector() '*' random_four_vector()^T | _ <- naturals(random_nat(10) + 1)];

define random_4_by_3_matrix() =
   sum[random_four_vector() '*' random_three_vector()^T | _ <- naturals(random_nat(10) + 1)];

# ------------------------------------------------------------------------------
# Test vectors
# ------------------------------------------------------------------------------

defindex Bar = {v0, v1, v2, v3, v4, v5};

defunit Bar!unit = {
    v0: second,
    v4: metre,
    v5: gram/second^2
};

define test_vec(v0, v1, v2, v3, v4, v5) =
   v0 '.*' delta(Bar@v0) +
   v1 '.*' delta(Bar@v1) +
   v2 '.*' delta(Bar@v2) +
   v3 '.*' delta(Bar@v3) +
   v4 '.*' delta(Bar@v4) +
   v5 '.*' delta(Bar@v5);

defindex Baz = {v0, v1};

defunit Baz!unit = {
    v0: second,
    v1: metre
};

define test_vec2(v0, v1) =
   v0 '.*' delta(Baz@v0) +
   v1 '.*' delta(Baz@v1);

# ------------------------------------------------------------------------------
# Indexing
# ------------------------------------------------------------------------------

define indexing_suite = test_suite("Indexing", [
    
   test("should work for scalars with _", () ->
      get(42, _, _) = 42
   ),
      
   test("should work for vectors with _", () ->
      get(test_vec(1,2,3,4,5,6), Bar@v3, _) = 4
   ),
      
   test("should work for transposed vectors with _", () ->
      get(test_vec(1,2,3,4,5,6)^T, _, Bar@v3) = 4
   )
]);

# ------------------------------------------------------------------------------
# Comprehensions
# ------------------------------------------------------------------------------

define comprehensions_suite = test_suite("Comprehension", [
    
    test("should count empty list as zero", () ->
        count[true | x <- []] = 0
    ),

    test("should count true as one", () ->
        count[true | x <- [1, 2, 3]] = 3
    ),

    test("should count false as zero", () ->
        count[false | x <- [1, 2, 3]] = 0
    ),
            
    test("count comprehension should filter correctly I", () ->
        count[mod(x, 2) = 0 | x <- naturals(10)] = 5
    ),
         
    test("count comprehension should filter correctly II", () ->
        count[ x < y | x <- naturals(10), y <- naturals(10)] = 45
    ),
             
    test("all comprehension should be true for empty list", () ->
        all[x | x <- []] = true
    ),
         
    test("some comprehension should be false for empty list", () ->
        some[x | x <- []] = false
    ),
             
    test("all comprehension should be true for non-empty list", () ->
        all[x < 5 | x <- [1,2,3]] = true
    ),
         
    test("some comprehension should be true for non-empty list", () ->
        some[x < 5 | x <- [1,2,3]] = true
    ),
             
    test("all comprehension should be false for non-empty list", () ->
        all[x < 3 | x <- [1,2,3]] = false
    ),
         
    test("some comprehension should be true for non-empty list", () ->
        some[x < 3 | x <- [1,2,3]] = true
    )
]);

# ------------------------------------------------------------------------------
