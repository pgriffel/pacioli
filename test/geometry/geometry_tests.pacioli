import si;
import testing;
import geometry;

declare geometry_suites :: List(TestSuite);

define geometry_suites = [
    vector2d_suite,
    vector3d_suite,
    norm_suite,
    normalized_suite,
    to_cartesian3d_suite,
    inclination_suite,
    azimuth_suite,
    polar_equations_suite
];

run_test_suites(geometry_suites); 

# ------------------------------------------------------------------------------
# Utils
# ------------------------------------------------------------------------------

define pick(xs) =
    nth(floor(list_size(xs) * random()), xs);

define random2d(u) =
    let c() = pick([-3, 0, 3]) * random() * u in
        vector2d(c() , c())
    end;

define random3d(u) =
    let c() = pick([-3, 0, 3]) * random() * u in
        vector3d(c() , c() , c())
    end;

# ------------------------------------------------------------------------------
# Functions vector2d
# ------------------------------------------------------------------------------

define vector2d_suite = test_suite("Function vector2d", [

    test("should construct vector correctly", () ->
        let vec = vector2d(100, 200) in
            get(vec, Geom2@x, _) = 100 and
            get(vec, Geom2@y, _) = 200
        end
    )
]);

# ------------------------------------------------------------------------------
# Functions vector3d
# ------------------------------------------------------------------------------

define vector3d_suite = test_suite("Function vector3d", [

    test("should construct vector correctly", () ->
        let vec = vector3d(100, 200, 500) in
            get(vec, Geom3@x, _) = 100 and
            get(vec, Geom3@y, _) = 200 and
            get(vec, Geom3@z, _) = 500
        end
    )
]);

# ------------------------------------------------------------------------------
# Functions norm
# ------------------------------------------------------------------------------

define norm_suite = test_suite("Function norm", [
   
    test("should be zero for zero vector", () ->
        let vec = vector2d(0, 0) in
            norm(vec) = 0
        end
    ),

   test("should be correct for 2d vector", () ->
        let vec = vector2d(100, 200) in
            norm(vec)^2 = 100^2 + 200^2
        end
    ),

   test("should be correct for 3d vector", () ->
        let vec = vector3d(100, 200, 300) in
           norm(vec)^2 = 100^2 + 200^2 + 300^2
        end
    )
]);

# ------------------------------------------------------------------------------
# Functions normalized
# ------------------------------------------------------------------------------

define normalized_suite = test_suite("Function normalized", [

    test("should normalize a vector in the x direction", () ->
        normalized(vector3d(10, 0, 0)) = vector3d(1, 0, 0)
    ),
   
    test("should normalize a vector in the x and y direction", () ->
        normalized(vector3d(3, 4, 0)) ~= vector3d(0.6, 0.8, 0)
    )
]);
 
# ------------------------------------------------------------------------------
# Functions to_cartesian3d
# ------------------------------------------------------------------------------


define to_cartesian3d_suite = test_suite("Function to_cartesian3d", [

    test("should transform correctly", () ->
        to_cartesian3d(4, pi*|radian|, 2*pi*|radian|) ~= vector3d(0, 0, -4)
    ),

    test("should transform correctly with units", () ->
        to_cartesian3d(4*|metre|, pi*|radian|/2, pi*|radian|) ~= |metre| '.*' vector3d(-4, 0, 0)
    )   
]);
 
# ------------------------------------------------------------------------------
# Functions inclination
# ------------------------------------------------------------------------------

define inclination_suite = test_suite("Function inclination", [

    test("should give correct result for vector (3,3,0)", () ->
        inclination(vector3d(3,3,0)) ~= 2*pi*|radian|/4
    )
]);

# ------------------------------------------------------------------------------
# Functions azimuth
# ------------------------------------------------------------------------------

define azimuth_suite = test_suite("Function azimuth", [

    test("should give correct result for vector (3,3,0)", () ->
        azimuth(vector3d(3,3,0)) = 2*pi*|radian|/8
    )
]);

# ------------------------------------------------------------------------------
# Functions azimuth
# ------------------------------------------------------------------------------

define polar_equations_suite = test_suite("Polar equations", [

    random_test("should by okay up to default precision using norm, polar_angle", () ->
        let
            v = random2d(|metre|),
            w = to_cartesian2d(norm(v), polar_angle(v))
        in
            just(v ~= w)
        end),
      
    random_test("should by okay up to 15 decimals using to_polar2d", () ->
        let
            v = random2d(|metre|), 
            w = let (nrm, ang) = to_polar2d(v) in
                    to_cartesian2d(nrm, ang) 
                end
        in
            just(v ~= w)
        end),

    random_test("should by okay up to 7 decimals using norm, inclination, azimuth", () ->
        let
            v = random3d(|metre|), 
            w = to_cartesian3d(norm(v), inclination(v), azimuth(v))
        in
            just(approximates(v, w, 7*|decimals|))
        end),
      
    random_test("should by okay up to 7 decimals using to_polar3d", () ->
        let
            v = random3d(|metre|), 
            w = let (nrm, inc, azi) = to_polar3d(v) in
                    to_cartesian3d(nrm, inc, azi) 
                end
        in
            just(approximates(v, w, 7*|decimals|))
        end
      )
]);
